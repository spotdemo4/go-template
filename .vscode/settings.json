{
  "files.associations": {
    "renovate.json": "jsonc",
    ".envrc.project": "dotenv",
    ".envrc": "dotenv"
  },

  "explorer.fileNesting.patterns": {
    ".envrc.project": ".envrc",
    "flake.nix": "flake.lock,treefmt.toml",
    "README.md": "*.md,LICENSE"
  },

  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/": true
  },

  "chat.tools.terminal.autoApprove": {
    // go
    "go run": true,
    "go mod tidy": true,

    // nix
    "nix fmt": true,
    "nix build": true,
    "nix flake check": true
  },

  // golang.go
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "go.buildTags": "dev",
  "gopls": { "ui.semanticTokens": true },

  // oxc.oxc-vscode
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,

  // jnoortheen.nix-ide
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}"
      }
    }
  }
}
